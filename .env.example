# ─── DATABASE ─────────────────────────────────────────────────────────────────
# On Railway, this is auto-injected as ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL="https://your-railway-domain.railway.app"
NEXTAUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"

# ─── GOOGLE OAUTH (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── SMTP (optional - for email verification & password reset) ────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@gorkhali-khabar.com"

# ─── CLOUDINARY (for image uploads) ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STORAGE_PROVIDER="local"

# ─── SITE URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://your-railway-domain.railway.app"

# ─── ADMIN IP WHITELIST (optional, comma-separated) ──────────────────────────
ADMIN_IP_WHITELIST=""
