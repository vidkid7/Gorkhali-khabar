# ─── DATABASE ─────────────────────────────────────────────────────────────────
# On Railway, this is auto-injected as ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL="https://your-railway-domain.railway.app"
NEXTAUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"

# ─── GOOGLE OAUTH (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── SMTP (optional - for email verification & password reset) ────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@gorkhali-khabar.com"

# ─── CLOUDINARY (for image uploads) ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STORAGE_PROVIDER="local"

# ─── REDIS (optional) ────────────────────────────────────────────────────────
REDIS_URL=""

# ─── SITE URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://your-railway-domain.railway.app"

# ─── ADMIN IP WHITELIST (optional, comma-separated) ──────────────────────────
ADMIN_IP_WHITELIST=""

# ─── ADMIN PANEL SECRET URL PATH ─────────────────────────────────────────────
# The admin panel will be accessible at /<ADMIN_SECRET_PATH> instead of /admin.
# Set to a random string like "secure-panel-x7k9m2" to hide the admin panel.
# If left as "admin" (default), the standard /admin path is used.
ADMIN_SECRET_PATH="admin"
NEXT_PUBLIC_ADMIN_SECRET_PATH="admin"

# ─── PRODUCTION SEEDING ONLY ─────────────────────────────────────────────────
# Required only if you intentionally run `npm run db:seed` with NODE_ENV=production.
SEED_ADMIN_PASSWORD=""
SEED_EDITOR_PASSWORD=""
SEED_AUTHOR_PASSWORD=""
